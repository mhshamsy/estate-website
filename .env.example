# Database Connection URL
# Use a relative path for portability: DATABASE_URL="file:./dev.db"
# If the relative path doesn't work, use an absolute path: 
# DATABASE_URL="file:/Users/username/project/dev.db"
DATABASE_URL="file:./dev.db"
# For SQLite, try relative path first: "file:./dev.db"
# If it fails, use absolute path: "file:/full/path/to/dev.db"

# NextAuth Configuration (If you are using NextAuth/Auth.js)
# You will need to generate a random secret for this
NEXTAUTH_SECRET="your_secret_here"
NEXTAUTH_URL="http://localhost:3000"

# Add other variables here as you create them
# For example:
# CLERK_API_KEY=""
# STRIPE_SECRET_KEY=""
